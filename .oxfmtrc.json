{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "ignorePatterns": [
    "**/.agent/skills",
    "**/.claude/skills",
    "**/.claude/worktrees",
    "**/test-results",
    "**/node_modules",
    "**/bun.lock",
    "**/apps/local-dashboard/dist",
    "**/*.md"
  ]
}
