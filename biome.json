{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "include": ["cli/**/*.ts", "tests/**/*.ts", "*.ts", "*.json", "*.md"],
    "ignore": ["node_modules", "bun.lock"]
  }
}
