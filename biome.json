{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "includes": [
      "**/cli/**/*.ts",
      "**/tests/**/*.ts",
      "**/*.ts",
      "**/*.json",
      "**/*.md",
      "!**/.claude/worktrees",
      "!**/node_modules",
      "!**/bun.lock"
    ]
  }
}
